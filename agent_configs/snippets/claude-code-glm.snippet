# ── claude-code-glm agent (Zhipu BigModel Anthropic-compatible API) ──
# EDIT ME: fill in your Zhipu BigModel API key (https://open.bigmodel.cn).
# The model name is injected by `harbor run --model <X>` at runtime; the
# claude_code adapter then mirrors ANTHROPIC_MODEL to all DEFAULT_*_MODEL
# aliases (see harbor claude_code.py:1094-1098), so we don't pin them here.
ENV ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic \
    ANTHROPIC_AUTH_TOKEN=<your-zhipu-api-key>

# Optional: bump Claude Code's per-request API timeout for slow GLM runs.
# Variant Dockerfiles already bake API_TIMEOUT_MS=600000 (10 min); GLM via
# Z.ai's Anthropic-compat layer can occasionally exceed that on long
# generations (PPT decks, multi-page reports). Uncomment the next line to
# raise the timeout to 50 minutes if you start seeing requests cut off.
# ENV API_TIMEOUT_MS=3000000
